{
  "name": "unified-terminal",
  "version": "0.1.0",
  "description": "Desktop app wrapping CLI AI tools for non-technical users",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "tsc && electron .",
    "build:main": "tsc",
    "dist:mac": "npm run build:main && electron-builder --mac",
    "dist:mac:arm64": "npm run build:main && electron-builder --mac --arm64",
    "dist:mac:x64": "npm run build:main && electron-builder --mac --x64"
  },
  "devDependencies": {
    "@electron/notarize": "^2.2.1",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.8",
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chokidar": "^3.6.0",
    "electron-updater": "^6.8.3",
    "node-pty": "^1.0.0",
    "tree-kill": "^1.2.2",
    "uuid": "^9.0.1"
  }
}
